generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth required models ──────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  trainingSessions TrainingSession[]
  dietEntries      DietEntry[]
  bodyMetrics      BodyMetric[]
  goals            Goal[]
}

model TrainingSession {
  id              String   @id @default(cuid())
  userId          String
  stravaId        String?  @unique // Strava activity ID for deduplication
  date            DateTime
  type            String   // run | bike | swim | strength | yoga | other
  name            String?  // activity name from Strava
  distance        Float?   // kilometers
  duration        Int      // minutes
  pace            Float?   // min/km
  heartRateAvg    Int?
  heartRateMax    Int?
  elevationGain   Float?   // meters
  calories        Int?
  perceivedEffort Int      // 1-10
  notes           String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DietEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  mealType  String   // breakfast | lunch | dinner | snack
  foodName  String
  calories  Int?
  protein   Float?   // grams
  carbs     Float?   // grams
  fat       Float?   // grams
  fiber     Float?   // grams
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BodyMetric {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime
  weight       Float?   // kg
  restingHR    Int?
  sleepHours   Float?
  sleepQuality Int?     // 1-10
  hrv          Int?
  vo2max       Float?
  notes        String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Goal {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  type         String    // distance | race | weight | pace | habit | other
  targetValue  Float?
  currentValue Float?
  unit         String?
  deadline     DateTime?
  completed    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
